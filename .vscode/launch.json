{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug pipeline (breakpoints in src/)",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/run-pipeline.mjs",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    },
    {
      "name": "Run dev server (netlify dev)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    }
  ]
}
